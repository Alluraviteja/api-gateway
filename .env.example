# API Gateway — environment variable reference.
# Copy to .env and fill in values for local development.

# ── Server ─────────────────────────────────────────
PORT=8080
LOG_LEVEL=info                  # debug | info | warn | error

# ── Rate Limiter Service ───────────────────────────
RATE_LIMITER_URL=http://localhost:9090

# ── Backend Routes ─────────────────────────────────
# Path to the YAML file that defines host → backend mappings.
# See routes.yaml for format. To add a new app, edit routes.yaml — no code change needed.
ROUTES_FILE=./routes.yaml

# ── Passthrough ────────────────────────────────────
# false = unknown hosts get 502 (recommended for production)
# true  = unknown hosts are proxied directly without rate limiting
ALLOW_PASSTHROUGH=false

# ── TLS (optional) ────────────────────────────────
# Both must be set to enable HTTPS. HTTP → HTTPS redirect is automatic.
TLS_CERT_FILE=
TLS_KEY_FILE=

# ── Observability ──────────────────────────────────
# Bearer token required to access GET /metrics.
# Leave empty to allow unauthenticated access (not recommended in production).
METRICS_TOKEN=

# ── Request limits ─────────────────────────────────
MAX_BODY_MB=10                  # Maximum request body size in megabytes
REQUEST_TIMEOUT_SECONDS=30      # Per-request timeout (cancels slow backends)
